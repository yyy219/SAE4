<?xml version="1.0" encoding="utf-8"?>

<!-- constraint layout conteneur le plus + puissant permet fixer element par rapport aux autres-->


<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">


    <!-- RelativeLayout pour pouvoir centrer la topbar, + ajout d'une contrainte pour fixer la barre en haut du telephone-->

    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/couleur_navy"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:background="@drawable/background_fond_label"
            android:backgroundTint="#2C4A6B"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/baseline_arrow_back_ios_24"
            android:contentDescription="Retour"
            app:tint="@color/blanc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nouvelle Formation"
            android:textColor="@color/blanc"
            android:textSize="@dimen/text_topbar"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:background="@drawable/background_fond_label"
            android:backgroundTint="#2C4A6B"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_more"
            android:contentDescription="Menu"
            app:tint="@color/blanc" />
    </RelativeLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_screen">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INFORMATIONS GÉNÉRALES"
                        android:textColor="@color/text_secondaire"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Titre de la formation"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_principal"
                        android:textSize="@dimen/text_label" />

                    <EditText
                        android:id="@+id/etTitre"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/field_height"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/background_label_choisi"
                        android:hint="Introduction à l'inclusion"
                        android:paddingHorizontal="12dp"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_principal"
                        android:textSize="@dimen/text_label" />

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/background_fond_label"
                        android:gravity="top"
                        android:hint="Comprendre les enjeux de l'inclusion sociale et agir au quotidien"
                        android:padding="12dp"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Durée (minutes)"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_principal"
                        android:textSize="@dimen/text_label" />

                    <EditText
                        android:id="@+id/etDuree"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/field_height"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/background_fond_label"
                        android:hint="45 minutes"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textSize="@dimen/text_body" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÉMATIQUE"
                        android:textColor="@color/text_secondaire"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupThematique"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInclusion"
                            style="@style/Widget.MaterialComponents.Chip.Entry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤝 Inclusion"
                            android:textColor="@color/chip_inclusion_text"
                            app:chipBackgroundColor="@color/chip_inclusion_bg"
                            app:chipStrokeColor="@color/chip_inclusion_text"
                            app:chipStrokeWidth="1.5dp"
                            app:chipIconVisible="false"
                            app:closeIconVisible="false" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEnv"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌿Environnement"
                            android:textColor="@color/chip_env_text"
                            app:chipBackgroundColor="@color/chip_env_bg"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEgalite"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚖️ Égalité"
                            android:textColor="@color/chip_egalite_text"
                            app:chipBackgroundColor="@color/chip_egalite_bg"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTolerance"
                            style="@style/Widget.MaterialComponents.Chip.Action"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❤️ Tolérance"
                            android:textColor="@color/chip_tolerance_text"
                            app:chipBackgroundColor="@color/chip_tolerance_bg"
                            app:chipStrokeWidth="0dp" />

                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESSIONS ASSOCIÉES"
                            android:textColor="@color/text_secondaire"
                            android:textSize="@dimen/text_label"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="2 sessions"
                            android:textColor="@color/text_secondaire"
                            android:textSize="10sp" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/background_session"
                        android:padding="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💻 En Ligne"
                                android:textStyle="bold"
                                android:textColor="@color/couleur_navy"
                                android:textSize="@dimen/text_body"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 mars 2026 • 09h-10h"
                                android:textColor="@color/text_secondaire"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/background_bleu_fonce"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="20 places"
                            android:textColor="@color/blanc"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/background_session"
                        android:padding="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍 Présentielle"
                                android:textStyle="bold"
                                android:textColor="@color/couleur_navy"
                                android:textSize="@dimen/text_body"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20 mars • 14h-16h, 15 places"
                                android:textColor="@color/text_secondaire"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/background_bleu_fonce"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="13 places"
                            android:textColor="@color/blanc"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAddSession"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/background_ajout_session"
                        android:text="+ Ajouter une session"
                        android:textAllCaps="false"
                        android:textColor="@color/text_secondaire"
                        android:textSize="@dimen/text_button" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>




        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_bar_height"
        android:background="@color/blanc"
        android:gravity="center"
        android:paddingHorizontal="@dimen/margin_screen"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:backgroundTint="@color/vert"
            android:text="Enregistrer la formation"
            android:textColor="@color/blanc"
            android:textAllCaps="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>